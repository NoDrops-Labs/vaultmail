# App database settings
MONGODB_URI=
MONGODB_DB=vaultmail

# Admin
ADMIN_PASSWORD=

# Webhook security (required for production)
WEBHOOK_SECRET=
ALLOW_UNAUTHENTICATED_WEBHOOK=  # set to 'true' ONLY for local dev

# Cron
CRON_SECRET=

# Optional frontend settings
NEXT_PUBLIC_ADSENSE_CLIENT_ID=

# Optional attachment limit
ATTACHMENT_MAX_BYTES=2000000

# Domains are configured via admin UI after deploy (no hardcoded list)
# Use VAULTMAIL_DOMAINS only as a reference for your own deployment
VAULTMAIL_DOMAINS=yourdomain1.com,yourdomain2.com

# Worker forwarding settings
WEBHOOK_URL=https://<your-app>.netlify.app/api/webhook
FORWARD_DOMAINS=yourdomain1.com,yourdomain2.com
FORWARD_EMAIL=

# Cloudflare Turnstile (optional - admin login bot protection)
# Leave unset to disable Turnstile during local dev.
TURNSTILE_SITE_KEY=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
